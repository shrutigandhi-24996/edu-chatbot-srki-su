# ============================================================
#  Educational Chatbot - environment configuration
#  Copy this file to `.env` and adjust as needed.
# ============================================================

# Default institution served by the chatbot: SRKI or SU
ACTIVE_INSTITUTION=SRKI

# ---- Server ----
HOST=127.0.0.1
PORT=8000

# ---- Dataset source paths (used only by scripts/prepare_data.py) ----
SRKI_DATASET_A=E:\Final Datsets\Final_SRKI_dataset\Dataset_A_SRKI.csv
SRKI_DATASET_B=E:\Final Datsets\Final_SRKI_dataset\Dataset_B_SRKI.csv
SU_DATASET_A=E:\Final Datsets\Final_SU_Dataset\SU_final_250k_A.csv
SU_DATASET_B=E:\Final Datsets\Final_SU_Dataset\SU_final_250k_B.csv

# ---- Intent model ----
# Base model used for FALLBACK zero-shot embeddings when no fine-tuned model exists.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Fine-tuned intent classifier. Either a local dir (models/<inst>_intent)
# or a Hugging Face Hub repo id, e.g. "your-user/srki-intent-distilbert".
SRKI_INTENT_MODEL=
SU_INTENT_MODEL=
INTENT_CONFIDENCE_THRESHOLD=0.45
MAX_SEQ_LENGTH=128

# ---- Answer generator (T5 / FLAN-T5) ----
USE_GENERATOR=false
# Local dir or HF Hub repo id of the fine-tuned generator. Falls back to base model.
SRKI_GENERATOR_MODEL=google/flan-t5-base
SU_GENERATOR_MODEL=google/flan-t5-base
GENERATOR_MAX_INPUT_CHARS=3000
GENERATOR_MAX_NEW_TOKENS=220

# ---- Web scraping (official sites) ----
WEB_SCRAPE_ENABLED=true
WEB_CACHE_TTL_HOURS=24
WEB_MAX_PAGES=40
WEB_REQUEST_TIMEOUT=15
WEB_REQUEST_DELAY_SEC=0.4

# ---- Out-of-domain handling ----
DOMAIN_GUARD_ENABLED=true

# ---- LLM answer brain (Groq - free, OpenAI-compatible) ----
# Get a free key at https://console.groq.com/keys . When set, answers are written
# by a hosted LLM grounded on the scraped official-site content (no GPU needed).
USE_LLM_BRAIN=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
